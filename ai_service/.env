# Desert Pulse Environment Variables
# Updated: 2025-01-30 with NEW API Key

# ============================================
# MongoDB Configuration
# ============================================
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=desert_pulse

# ============================================
# Gemini API Configuration - NEW KEY
# ============================================
# Your NEW Gemini API Key (created Jan 2026)
GEMINI_API_KEY=AIzaSyAjNBTQD7hHFXkLDOuDL86p_MyQHTS13bk

# Gemini Model
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# Security Settings
# ============================================
SECRET_KEY=desert-pulse-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# Feature Flags
# ============================================
ENABLE_NOTIFICATIONS=True
ENABLE_AI_COACH=True
ENABLE_WEEKLY_REPORTS=True
ENABLE_WORKOUT_GENERATION=True

# ============================================
# AI Settings
# ============================================
# Coach Settings
AI_COACH_MAX_TOKENS=800
AI_COACH_TEMPERATURE=0.8
AI_COACH_TIMEOUT=60

# Workout Generation Settings
WORKOUT_GEN_MAX_TOKENS=2000
WORKOUT_GEN_TEMPERATURE=0.7
WORKOUT_GEN_TIMEOUT=60

# Retry Settings - Important for rate limits
MAX_RETRIES=3
RETRY_DELAY=2

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
